<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewmodels="clr-namespace:FleetManager.ViewModels"
             mc:Ignorable="d"
             x:Class="FleetManager.Views.VehicleItemView"
             x:DataType="viewmodels:VehicleItemViewModel">

    <StackPanel Width="400" Margin="10" Spacing="5">

        <!-- Dane pojazdu -->
        <TextBlock Text="{Binding Vehicle.Name}" FontWeight="Bold" />
        <TextBlock Text="{Binding Vehicle.RegNumber}" FontStyle="Italic"/>
        <TextBlock Text="{Binding Vehicle.FuelLevel}"/>
        <TextBlock Text="{Binding Vehicle.Status}"/>

        <!-- Przyciski -->
        <StackPanel Orientation="Horizontal" Spacing="5" Margin="0,10,0,0">
            <Button Content="Tankuj" Command="{Binding RefuelCommand}" />
            <Button Content="Wyślij" Command="{Binding SendInRouteCommand}" />
            <Button Content="Dostępny" Command="{Binding SetAvailableCommand}" />
            <Button Content="Serwis" Command="{Binding SetServiceCommand}" />
        </StackPanel>

    </StackPanel>

</UserControl>