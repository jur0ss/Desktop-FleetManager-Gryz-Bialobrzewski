<!-- (UserControl - widok) -->

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="clr-namespace:FleetManager.Models"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="FleetManager.Views.VehicleItemView"
             x:DataType="models:Vehicle">

    <StackPanel Width="400" Margin="10" Spacing="5">
        <TextBlock Text="{Binding Name}" FontWeight="Bold" />
        <TextBlock Text="{Binding RegNumber}" FontStyle="Italic"/>
        <TextBlock Text="{Binding FuelLevel}"/>
        <TextBlock Text="{Binding Status}"/>
    </StackPanel>
    
</UserControl>
